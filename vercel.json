{
  "version": 2,
  "builds": [
    {
      "src": "app.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/app.js"
    },
    {
      "src": "/health",
      "dest": "/app.js"
    },
    {
      "src": "/debug",
      "dest": "/app.js"
    },
    {
      "src": "/deliveries(.*)",
      "dest": "/app.js"
    },
    {
      "src": "/orders(.*)",
      "dest": "/app.js"
    },
    {
      "src": "/customers(.*)",
      "dest": "/app.js"
    },
    {
      "src": "/export",
      "dest": "/app.js"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/dist/$1"
    }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}